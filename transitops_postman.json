	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"if (pm.response.code === 200 && pm.info.requestName === 'Login') {",
					"    var jsonData = pm.response.json();",
					"    if (jsonData.token) {",
					"        pm.collectionVariables.set('jwt_token', jsonData.token);",
					"    }",
					"}"
				]
			}
		}
	],
	"variable": [
		{
			"key": "jwt_token",
